generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

enum Gender {
  HOMBRE
  MUJER
  UNISEX
}

enum ProductType {
  EDP
  BODY_MIST
  MUESTRA
}

model Product {
  id         Int         @id @default(autoincrement())
  name       String
  size       String?
  gender     Gender
  type       ProductType
  cost       Decimal     @db.Decimal(12, 2)
  marginPct  Decimal     @map("margin_pct") @db.Decimal(5, 4)
  salePrice  Decimal     @map("sale_price") @db.Decimal(12, 2)
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  purchases Purchase[]
  sales     Sale[]

  @@map("products")
}

model Purchase {
  id        Int      @id @default(autoincrement())
  productId Int      @map("product_id")
  date      DateTime
  quantity  Int
  unitPrice Decimal  @map("unit_price") @db.Decimal(12, 2)
  total     Decimal  @db.Decimal(12, 2)
  notes     String?
  receiptNum String? @map("receipt_num")
  createdAt DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("purchases")
}

model Sale {
  id           Int      @id @default(autoincrement())
  productId    Int      @map("product_id")
  date         DateTime
  quantity     Int
  salePrice    Decimal  @map("sale_price") @db.Decimal(12, 2)
  totalRevenue Decimal  @map("total_revenue") @db.Decimal(12, 2)
  totalCost    Decimal  @map("total_cost") @db.Decimal(12, 2)
  grossProfit  Decimal  @map("gross_profit") @db.Decimal(12, 2)
  isSold       Boolean  @default(false) @map("is_sold")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("sales")
}
